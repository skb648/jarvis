# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/
app/build/

# Local configuration file
local.properties

# Android Studio
.idea/
*.iml
.navigation/
captures/

# Keystore files (keep out of version control)
*.jks
*.keystore

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# Rust build artifacts (target directory is large)
rust/target/

# CMake / NDK build cache
app/.cxx/

# DO NOT ignore jniLibs — they contain pre-built .so files needed for the APK
# DO NOT ignore Cargo.lock — it's needed for reproducible builds
!app/src/main/jniLibs/
